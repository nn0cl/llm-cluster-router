{
  "hosts": [
    {
      "label": "local-lan-primary",
      "provider": "ollama",
      "url": "http://192.168.0.30:11434",
      "priority": 100,
      "timeout_seconds": 30
    },
    {
      "label": "local-lan-secondary",
      "provider": "ollama",
      "url": "http://192.168.0.136:11434",
      "priority": 10,
      "timeout_seconds": 30
    },
    {
      "label": "openai-api",
      "provider": "openai",
      "url": "https://api.openai.com",
      "priority": 5,
      "timeout_seconds": 60,
      "api_key_env": "OPENAI_API_KEY",
      "models": ["gpt-5.4"]
    },
    {
      "label": "claude-api",
      "provider": "anthropic",
      "url": "https://api.anthropic.com",
      "priority": 4,
      "timeout_seconds": 60,
      "api_key_env": "ANTHROPIC_API_KEY",
      "anthropic_version": "2023-06-01",
      "models": ["claude-sonnet-4-5"],
      "task_profiles": ["hard", "agentic", "long-context"]
    },
    {
      "label": "local-codex-sdk",
      "provider": "codex",
      "url": "local-codex-sdk",
      "priority": 3,
      "timeout_seconds": 60,
      "models": ["gpt-5.4"],
      "task_profiles": ["agentic", "workspace-edit", "code-review"]
    }
  ],
  "defaults": {
    "allowed_root": ".",
    "keep_alive": "10m"
  },
  "routing_guidance": {
    "easy": {
      "preferred_provider": "ollama",
      "notes": "Prefer configured local Ollama models for small, local, low-risk tasks."
    },
    "hard": {
      "preferred_provider": "anthropic",
      "notes": "Prefer configured Claude models for architecture-sensitive, ambiguous, or long-context reasoning tasks."
    },
    "agentic": {
      "preferred_provider": "codex",
      "notes": "Prefer configured Codex SDK models for multi-step workspace coding tasks when the SDK is available."
    }
  }
}
